<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucv.lab12.controller.DeudaDocenteFormController"
      spacing="14"
      style="-fx-padding:24; -fx-background-color:white;"
      prefWidth="500">

    <!-- Título -->
    <Label fx:id="lblTitulo" text="Deuda de Docente"
           style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#1565C0;">
        <font><Font size="20.0"/></font>
    </Label>
    <Separator/>

    <!-- Formulario -->
    <GridPane hgap="12" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="140" prefWidth="150" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="260"/>
        </columnConstraints>

        <!-- Docente -->
        <Label text="Nombre del Docente: *" GridPane.rowIndex="0" GridPane.columnIndex="0"
               style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="0" GridPane.columnIndex="1" spacing="2">
            <TextField fx:id="txtNombreDocente" promptText="Ingrese nombre completo…" maxWidth="Infinity"/>
            <Label fx:id="lblNombreDocenteError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <!-- DNI -->
        <Label text="DNI: *" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="1" GridPane.columnIndex="1" spacing="2">
            <TextField fx:id="txtDni" promptText="8 dígitos…" maxWidth="Infinity"/>
            <Label fx:id="lblDniError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <!-- Tipo de Deuda -->
        <Label text="Tipo de Deuda: *" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight:bold;"/>
        <ComboBox fx:id="cmbTipoDeuda" promptText="Seleccione…" maxWidth="Infinity"
                  GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <!-- Monto -->
        <Label text="Monto (S/): *" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="3" GridPane.columnIndex="1" spacing="2">
            <TextField fx:id="txtMonto" promptText="Ej: 1500.50" maxWidth="Infinity"/>
            <Label fx:id="lblMontoError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <!-- Fecha de la deuda -->
        <Label text="Fecha de la Deuda: *" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dpFechaDeuda" maxWidth="Infinity"
                    GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <!-- Fecha de vencimiento -->
        <Label text="Fecha de Vencimiento: *" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dpFechaVencimiento" maxWidth="Infinity"
                    GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <!-- Situación laboral -->
        <Label text="Situación Laboral: *" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cmbSituacionLaboral" promptText="Seleccione…" maxWidth="Infinity"
                  GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <!-- Estado -->
        <Label text="Estado:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cmbEstado" maxWidth="Infinity"
                  GridPane.rowIndex="7" GridPane.columnIndex="1"/>

        <!-- Observaciones -->
        <Label text="Observaciones:" GridPane.rowIndex="8" GridPane.columnIndex="0"
               GridPane.valignment="TOP"/>
        <TextArea fx:id="txtObservaciones" promptText="Observaciones adicionales…"
                  GridPane.rowIndex="8" GridPane.columnIndex="1"
                  prefHeight="72" wrapText="true"/>
    </GridPane>

    <Label text="(*) Campo obligatorio"
           style="-fx-font-size:11; -fx-text-fill:#757575;"/>

    <!-- Botones -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar"
                prefWidth="100"
                style="-fx-cursor:hand;"/>
        <Button fx:id="btnGuardar" text="Guardar" onAction="#onGuardar"
                defaultButton="true" prefWidth="100"
                style="-fx-background-color:#1976D2;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </HBox>

</VBox>
